# Backend API base URL
# VITE_API_BASE_URL=https://your-backend.domain

# Endpoint overrides are optional. By default, the app uses:
# /auth/email/send
# /auth/email/verify
# /auth/signup
# /auth/login
# /auth/reissue
# /auth/logout

# 개발용 임시 모드(백엔드 없을 때 true)
# true면 실제 auth API 호출 없이 mock 응답으로 동작
VITE_MOCK_AUTH_API=false
VITE_MOCK_AUTH_DELAY_MS=500
VITE_MOCK_VERIFICATION_CODE=123456
