# Backend API base URL
# Use the Vite proxy in local development to avoid CORS issues.
# Leave VITE_API_BASE_URL empty and set VITE_PROXY_API_TARGET to the backend URL.
VITE_API_BASE_URL=
VITE_PROXY_API_TARGET=http://your-backend.domain

# Use this only when the browser should call the API directly without a proxy,
# such as in a deployed frontend environment.
# VITE_API_BASE_URL=https://your-backend.domain

# Endpoint overrides are optional. By default, the app uses:
# /auth/email/send
# /auth/email/verify
# /auth/signup
# /auth/login
# /auth/reissue
# /auth/logout

# Temporary development mode for when the backend is unavailable.
# Set to true to use mock auth responses instead of real auth API calls.
VITE_MOCK_AUTH_API=false
VITE_MOCK_AUTH_DELAY_MS=500
VITE_MOCK_VERIFICATION_CODE=123456
VITE_MOCK_VERIFICATION_DELAY_MS=500

# User API mock mode.
# Set to true to mock endpoints such as /user/me and /user/me/achievement.
VITE_MOCK_USER_API=false
VITE_MOCK_USER_DELAY_MS=300

# Subscription API mock mode.
# Set to true to mock /subscription/plan responses.
VITE_MOCK_SUBSCRIPTION_API=false
VITE_MOCK_SUBSCRIPTION_DELAY_MS=300
